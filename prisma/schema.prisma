generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/stock-history.db"
}

model Account {
  id            String   @id
  broker        String
  accountNumber String
  nickname      String?
  memo          String?
  createdAt     String
  updatedAt     String
  trades        Trade[]
}

model Trade {
  id          String      @id
  accountId   String
  symbol      String
  symbolCode  String?
  comment     String?
  createdAt   String
  updatedAt   String
  account     Account     @relation(fields: [accountId], references: [id])
  buyEntries  BuyEntry[]
  sellEntries SellEntry[]
}

model CoinTrade {
  id          String           @id
  symbol      String
  comment     String?
  createdAt   String
  updatedAt   String
  buyEntries  CoinBuyEntry[]
  sellEntries CoinSellEntry[]
}

model CoinBuyEntry {
  id        String    @id
  tradeId   String
  date      String
  price     Float
  quantity  Float
  createdAt String
  trade     CoinTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model CoinSellEntry {
  id        String    @id
  tradeId   String
  date      String
  price     Float
  quantity  Float
  createdAt String
  trade     CoinTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model StockMaster {
  id          String @id
  symbol      String @unique
  symbolCode  String
  createdAt   String
  updatedAt   String
}

model Memo {
  id          String  @id
  content     String
  showOnMain  Boolean @default(true)
  showOnCoin  Boolean @default(true)
  createdAt   String
  updatedAt   String
}

model BuyEntry {
  id        String @id
  tradeId   String
  date      String
  price     Float
  quantity  Int
  createdAt String
  trade     Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model SellEntry {
  id        String @id
  tradeId   String
  date      String
  price     Float
  quantity  Int
  createdAt String
  trade     Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}
