generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/stock-history.db"
}

model Account {
  id            String   @id
  broker        String
  accountNumber String
  nickname      String?
  memo          String?
  createdAt     String
  updatedAt     String
  trades        Trade[]
}

model Trade {
  id          String      @id
  accountId   String
  symbol      String
  symbolCode  String?
  comment     String?
  createdAt   String
  updatedAt   String
  account     Account     @relation(fields: [accountId], references: [id])
  buyEntries  BuyEntry[]
  sellEntries SellEntry[]
}

model BuyEntry {
  id        String @id
  tradeId   String
  date      String
  price     Float
  quantity  Int
  createdAt String
  trade     Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model SellEntry {
  id        String @id
  tradeId   String
  date      String
  price     Float
  quantity  Int
  createdAt String
  trade     Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}
